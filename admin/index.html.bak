<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>لوحة التحكم — جمعية إرث وحضارة</title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Amiri:ital,wght@0,400;0,700;1,400&family=Tajawal:wght@300;400;500;700&family=Cormorant+Garamond:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet" />
<style>
  :root {
    --ivory: #f2eadb;
    --ivory-2: #ece2cf;
    --ivory-3: #e6dcc6;
    --paper: #f7f0e1;
    --sand: #e2d3b8;
    --sand-deep: #c9b690;
    --ink: #2a1f14;
    --ink-soft: #4a3a28;
    --ink-muted: #7a6750;
    --ink-faint: #a99578;
    --gold: #8b6b3c;
    --gold-soft: #a88654;
    --line: rgba(42, 31, 20, 0.14);
    --line-soft: rgba(42, 31, 20, 0.08);
    --danger: #8a2e1f;
    --success: #4a6b3c;
    --shadow-card: 0 1px 0 rgba(42,31,20,0.04), 0 18px 40px -28px rgba(42,31,20,0.18);
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  html, body {
    background: var(--ivory);
    color: var(--ink);
    font-family: "Tajawal", system-ui, sans-serif;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    text-rendering: optimizeLegibility;
    min-height: 100vh;
  }

  button { font-family: inherit; cursor: pointer; }
  input, textarea, select { font-family: inherit; color: inherit; }
  a { color: inherit; text-decoration: none; }
  img { display: block; max-width: 100%; }

  /* paper grain */
  .grain {
    position: fixed; inset: 0; pointer-events: none; z-index: 200;
    opacity: 0.25; mix-blend-mode: multiply;
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='240' height='240'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='2' seed='4' stitchTiles='stitch'/><feColorMatrix values='0 0 0 0 0.16  0 0 0 0 0.12  0 0 0 0 0.08  0 0 0 0.12 0'/></filter><rect width='100%25' height='100%25' filter='url(%23n)'/></svg>");
  }

  /* ============ APP SHELL ============ */
  .app {
    display: grid;
    grid-template-columns: 280px 1fr;
    min-height: 100vh;
  }

  /* ---- Sidebar ---- */
  .sidebar {
    background: var(--paper);
    border-left: 1px solid var(--line);
    padding: 28px 22px 22px;
    display: flex;
    flex-direction: column;
    gap: 28px;
    position: sticky;
    top: 0;
    height: 100vh;
    overflow-y: auto;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 14px;
    padding-bottom: 22px;
    border-bottom: 1px solid var(--line-soft);
  }
  .brand-seal {
    width: 44px; height: 44px;
    border: 1px solid var(--ink);
    border-radius: 50%;
    display: grid; place-items: center;
    position: relative;
    flex-shrink: 0;
  }
  .brand-seal::before {
    content: ""; position: absolute; inset: 4px;
    border: 1px solid var(--line); border-radius: 50%;
  }
  .brand-seal svg { width: 20px; height: 20px; }
  .brand-text { line-height: 1; }
  .brand-text .ar {
    font-family: "Amiri", serif; font-weight: 700;
    font-size: 16px; color: var(--ink); letter-spacing: 0.3px;
  }
  .brand-text .latin {
    font-family: "Cormorant Garamond", serif; font-style: italic;
    font-size: 11px; color: var(--ink-muted);
    letter-spacing: 0.18em; text-transform: uppercase;
    margin-top: 6px; display: block;
  }

  .nav-section-label {
    font-family: "Cormorant Garamond", serif; font-style: italic;
    font-size: 11.5px; letter-spacing: 0.28em; text-transform: uppercase;
    color: var(--ink-muted);
    padding: 0 10px 12px;
    display: flex; align-items: center; gap: 10px;
  }
  .nav-section-label::after {
    content: ""; flex: 1; height: 1px; background: var(--line-soft);
  }

  .nav-list { list-style: none; display: flex; flex-direction: column; gap: 2px; }
  .nav-item {
    display: flex; align-items: center; gap: 14px;
    padding: 11px 12px; border-radius: 2px;
    color: var(--ink-soft); font-size: 14.5px;
    cursor: pointer; position: relative;
    border: 1px solid transparent;
    transition: all 0.3s ease;
    width: 100%; text-align: right; background: transparent;
  }
  .nav-item:hover { background: var(--ivory-2); color: var(--ink); }
  .nav-item.active {
    background: var(--ink); color: var(--ivory);
    border-color: var(--ink);
  }
  .nav-item.active .nav-icon { color: var(--gold-soft); }
  .nav-icon {
    width: 18px; height: 18px;
    color: var(--ink-muted);
    flex-shrink: 0;
  }
  .nav-item:hover .nav-icon { color: var(--ink); }
  .nav-label { flex: 1; }
  .nav-badge {
    background: var(--gold);
    color: var(--ivory);
    font-family: "Cormorant Garamond", serif; font-style: italic;
    font-size: 11px; letter-spacing: 0.08em;
    padding: 2px 8px; border-radius: 999px;
    min-width: 22px; text-align: center;
  }
  .nav-item.active .nav-badge { background: var(--gold-soft); color: var(--ink); }

  .sidebar-foot {
    margin-top: auto;
    padding-top: 22px;
    border-top: 1px solid var(--line-soft);
    display: flex; align-items: center; gap: 12px;
  }
  .avatar {
    width: 38px; height: 38px; border-radius: 50%;
    background: var(--sand); display: grid; place-items: center;
    font-family: "Amiri", serif; font-weight: 700;
    color: var(--ink); border: 1px solid var(--line);
  }
  .sidebar-foot .who { line-height: 1.3; flex: 1; }
  .sidebar-foot .who .name { font-size: 13.5px; color: var(--ink); }
  .sidebar-foot .who .role {
    font-family: "Cormorant Garamond", serif; font-style: italic;
    font-size: 11.5px; color: var(--ink-muted); letter-spacing: 0.1em;
  }
  .icon-btn {
    width: 32px; height: 32px; border-radius: 50%;
    border: 1px solid var(--line); background: transparent;
    display: grid; place-items: center;
    color: var(--ink-muted); transition: all 0.3s ease;
  }
  .icon-btn:hover { border-color: var(--ink); color: var(--ink); }
  .icon-btn svg { width: 14px; height: 14px; }

  /* ---- Main ---- */
  .main {
    display: flex; flex-direction: column;
    min-height: 100vh;
  }

  .topbar {
    display: flex; align-items: center; gap: 24px;
    padding: 22px 44px;
    border-bottom: 1px solid var(--line-soft);
    background: var(--ivory);
    position: sticky; top: 0; z-index: 50;
  }
  .menu-toggle {
    display: none; width: 36px; height: 36px; border-radius: 2px;
    border: 1px solid var(--line); background: transparent;
    align-items: center; justify-content: center;
    color: var(--ink);
  }
  .menu-toggle svg { width: 18px; height: 18px; }
  .crumbs { display: flex; align-items: center; gap: 14px; flex: 1; }
  .crumbs .crumb {
    font-family: "Cormorant Garamond", serif; font-style: italic;
    font-size: 13px; color: var(--ink-muted); letter-spacing: 0.16em;
    text-transform: uppercase;
  }
  .crumbs .sep { color: var(--ink-faint); font-size: 12px; }
  .crumbs .current {
    font-family: "Tajawal", sans-serif; font-style: normal;
    font-size: 14.5px; color: var(--ink); letter-spacing: 0.01em;
    text-transform: none;
  }
  .topbar-search {
    display: flex; align-items: center; gap: 10px;
    padding: 8px 14px;
    background: var(--paper);
    border: 1px solid var(--line-soft);
    border-radius: 2px;
    width: 280px;
    transition: border-color 0.3s ease;
  }
  .topbar-search:focus-within { border-color: var(--ink); }
  .topbar-search svg { width: 14px; height: 14px; color: var(--ink-muted); }
  .topbar-search input {
    flex: 1; border: 0; background: transparent; outline: none;
    font-size: 14px;
  }
  .topbar-actions { display: flex; align-items: center; gap: 10px; }
  .bell-btn {
    position: relative;
    width: 38px; height: 38px; border-radius: 50%;
    border: 1px solid var(--line); background: transparent;
    display: grid; place-items: center; color: var(--ink-soft);
    transition: all 0.3s ease;
  }
  .bell-btn:hover { border-color: var(--ink); color: var(--ink); }
  .bell-btn svg { width: 16px; height: 16px; }
  .bell-btn .dot {
    position: absolute; top: 8px; right: 8px;
    width: 7px; height: 7px; border-radius: 50%;
    background: var(--gold);
    box-shadow: 0 0 0 3px var(--ivory);
  }

  /* ---- Page content ---- */
  .page {
    padding: 36px 44px 60px;
    flex: 1;
  }
  .page-head { margin-bottom: 36px; }
  .page-eyebrow {
    display: flex; align-items: center; gap: 14px;
    margin-bottom: 16px;
  }
  .page-eyebrow .dot {
    width: 6px; height: 6px; border-radius: 50%; background: var(--gold);
    box-shadow: 0 0 0 4px rgba(139,107,60,0.12);
  }
  .page-eyebrow .latin {
    font-family: "Cormorant Garamond", serif; font-style: italic;
    font-size: 13px; color: var(--ink-muted); letter-spacing: 0.18em;
  }
  .page-eyebrow .label {
    font-size: 12.5px; letter-spacing: 0.22em; color: var(--ink-muted);
    border-right: 1px solid var(--line); padding-right: 16px; font-weight: 500;
  }
  .page-title {
    font-family: "Amiri", serif; font-weight: 400;
    font-size: clamp(34px, 4vw, 52px); line-height: 1.15;
    color: var(--ink); margin-bottom: 12px;
  }
  .page-title .accent { font-style: italic; color: var(--gold); }
  .page-sub {
    font-size: 15px; color: var(--ink-soft); line-height: 1.7;
    max-width: 720px;
  }

  /* ---- Common buttons ---- */
  .btn {
    display: inline-flex; align-items: center; gap: 10px;
    padding: 12px 22px; border-radius: 2px;
    font-size: 14px; font-weight: 500; letter-spacing: 0.01em;
    border: 1px solid transparent; cursor: pointer;
    transition: all 0.35s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .btn svg { width: 14px; height: 14px; }
  .btn-primary { background: var(--ink); color: var(--ivory); border-color: var(--ink); }
  .btn-primary:hover { background: transparent; color: var(--ink); }
  .btn-ghost { background: transparent; color: var(--ink); border-color: var(--line); }
  .btn-ghost:hover { border-color: var(--ink); background: var(--ivory-2); }
  .btn-danger { background: transparent; color: var(--danger); border-color: rgba(138,46,31,0.3); }
  .btn-danger:hover { background: var(--danger); color: var(--ivory); border-color: var(--danger); }
  .btn-sm { padding: 7px 14px; font-size: 13px; }

  /* ---- Cards ---- */
  .card {
    background: var(--paper);
    border: 1px solid var(--line-soft);
    border-radius: 2px;
    padding: 28px;
    position: relative;
  }
  .card-head {
    display: flex; align-items: center; justify-content: space-between;
    gap: 24px; margin-bottom: 22px;
  }
  .card-head h3 {
    font-family: "Amiri", serif; font-weight: 700;
    font-size: 22px; color: var(--ink);
  }
  .card-head .latin {
    font-family: "Cormorant Garamond", serif; font-style: italic;
    font-size: 12px; color: var(--ink-muted); letter-spacing: 0.18em;
    text-transform: uppercase; margin-top: 4px;
  }

  /* ---- Stat cards ---- */
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 22px;
    margin-bottom: 44px;
  }
  .stat {
    background: var(--paper);
    border: 1px solid var(--line-soft);
    padding: 26px 24px 24px;
    position: relative;
    overflow: hidden;
  }
  .stat::before {
    content: ""; position: absolute; top: 0; right: 0;
    width: 2px; height: 38px; background: var(--gold);
  }
  .stat .stat-eyebrow {
    display: flex; align-items: center; gap: 10px;
    font-family: "Cormorant Garamond", serif; font-style: italic;
    font-size: 12px; letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--ink-muted);
    margin-bottom: 18px;
  }
  .stat .stat-eyebrow svg { width: 13px; height: 13px; color: var(--gold); }
  .stat .stat-label {
    font-size: 14.5px; color: var(--ink-soft); margin-bottom: 14px;
  }
  .stat .stat-value {
    font-family: "Amiri", serif; font-weight: 700;
    font-size: 52px; line-height: 1; color: var(--ink);
    letter-spacing: -0.01em;
  }
  .stat .stat-foot {
    margin-top: 18px;
    padding-top: 14px;
    border-top: 1px solid var(--line-soft);
    display: flex; align-items: center; justify-content: space-between;
    font-size: 12.5px; color: var(--ink-muted);
  }
  .stat .stat-foot .delta { color: var(--success); font-family: "Cormorant Garamond", serif; font-style: italic; letter-spacing: 0.05em; }

  /* ---- Two-col grid for home ---- */
  .grid-2 {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 24px;
  }

  .activity-list { display: flex; flex-direction: column; }
  .activity-item {
    display: flex; gap: 16px;
    padding: 16px 0;
    border-bottom: 1px solid var(--line-soft);
  }
  .activity-item:last-child { border-bottom: 0; }
  .activity-marker {
    width: 36px; height: 36px; border-radius: 50%;
    background: var(--ivory-2); display: grid; place-items: center;
    color: var(--ink-soft); flex-shrink: 0;
    border: 1px solid var(--line-soft);
  }
  .activity-marker svg { width: 14px; height: 14px; }
  .activity-body { flex: 1; }
  .activity-title { font-size: 14.5px; color: var(--ink); margin-bottom: 4px; }
  .activity-meta {
    font-family: "Cormorant Garamond", serif; font-style: italic;
    font-size: 12px; color: var(--ink-muted); letter-spacing: 0.08em;
  }

  /* ---- Toolbar (above tables) ---- */
  .toolbar {
    display: flex; align-items: center; gap: 14px;
    margin-bottom: 24px; flex-wrap: wrap;
  }
  .toolbar .search-input {
    flex: 1; max-width: 360px;
    display: flex; align-items: center; gap: 10px;
    padding: 10px 14px;
    background: var(--paper);
    border: 1px solid var(--line-soft);
    border-radius: 2px;
  }
  .toolbar .search-input svg { width: 14px; height: 14px; color: var(--ink-muted); }
  .toolbar .search-input input {
    flex: 1; border: 0; background: transparent; outline: none;
    font-size: 14px;
  }
  .toolbar .filters { display: flex; gap: 8px; }
  .chip {
    padding: 7px 14px; font-size: 12.5px;
    border: 1px solid var(--line); border-radius: 999px;
    background: transparent; color: var(--ink-soft);
    letter-spacing: 0.02em;
    transition: all 0.3s ease;
  }
  .chip:hover { border-color: var(--ink-muted); }
  .chip.active { background: var(--ink); color: var(--ivory); border-color: var(--ink); }
  .toolbar .spacer { flex: 1; }

  /* ---- Tables ---- */
  .table-wrap {
    background: var(--paper);
    border: 1px solid var(--line-soft);
    overflow: hidden;
  }
  table.data { width: 100%; border-collapse: collapse; }
  table.data thead th {
    text-align: right;
    font-family: "Cormorant Garamond", serif; font-style: italic;
    font-weight: 500; font-size: 12px; letter-spacing: 0.22em;
    text-transform: uppercase; color: var(--ink-muted);
    padding: 16px 20px;
    border-bottom: 1px solid var(--line);
    background: var(--ivory-3);
  }
  table.data tbody td {
    padding: 18px 20px;
    border-bottom: 1px solid var(--line-soft);
    font-size: 14.5px; color: var(--ink-soft);
    vertical-align: middle;
  }
  table.data tbody tr:last-child td { border-bottom: 0; }
  table.data tbody tr:hover { background: rgba(226, 211, 184, 0.18); }
  table.data .name-cell {
    display: flex; align-items: center; gap: 12px;
    color: var(--ink);
  }
  table.data .thumb {
    width: 44px; height: 44px; border-radius: 2px;
    background: var(--sand); flex-shrink: 0; object-fit: cover;
  }
  table.data .row-status {
    display: inline-flex; align-items: center; gap: 8px;
    font-family: "Cormorant Garamond", serif; font-style: italic;
    font-size: 12.5px; letter-spacing: 0.1em;
    padding: 4px 12px; border-radius: 999px;
    border: 1px solid var(--line);
  }
  .row-status.new { color: var(--gold); border-color: rgba(139,107,60,0.4); }
  .row-status.new::before {
    content: ""; width: 6px; height: 6px; border-radius: 50%;
    background: var(--gold);
  }
  .row-status.reviewed { color: var(--success); border-color: rgba(74,107,60,0.3); }
  .row-status.reviewed::before {
    content: ""; width: 6px; height: 6px; border-radius: 50%;
    background: var(--success);
  }
  .row-actions { display: flex; gap: 8px; justify-content: flex-start; }
  .row-actions button {
    border: 1px solid var(--line); background: transparent;
    color: var(--ink-soft); padding: 6px 10px; border-radius: 2px;
    font-size: 12px; transition: all 0.3s ease;
    display: inline-flex; align-items: center; gap: 6px;
  }
  .row-actions button svg { width: 12px; height: 12px; }
  .row-actions button:hover { border-color: var(--ink); color: var(--ink); }
  .row-actions .del:hover { border-color: var(--danger); color: var(--danger); }
  .row-actions .ok:hover { border-color: var(--success); color: var(--success); }

  .empty-state {
    padding: 60px 30px; text-align: center;
    color: var(--ink-muted);
  }
  .empty-state .glyph {
    font-family: "Amiri", serif; font-size: 36px;
    color: var(--gold-soft); margin-bottom: 14px;
  }
  .empty-state .latin {
    font-family: "Cormorant Garamond", serif; font-style: italic;
    font-size: 13px; letter-spacing: 0.18em; text-transform: uppercase;
    color: var(--ink-faint); margin-top: 8px;
  }

  /* ---- News cards (grid view) ---- */
  .news-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(290px, 1fr));
    gap: 22px;
  }
  .news-card {
    background: var(--paper);
    border: 1px solid var(--line-soft);
    display: flex; flex-direction: column;
    position: relative;
    overflow: hidden;
    transition: all 0.4s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .news-card:hover { box-shadow: var(--shadow-card); transform: translateY(-2px); }
  .news-card .cover {
    aspect-ratio: 4/3; background: var(--sand);
    position: relative; overflow: hidden;
  }
  .news-card .cover img {
    width: 100%; height: 100%; object-fit: cover;
  }
  .news-card .cover.empty {
    background:
      repeating-linear-gradient(118deg, rgba(42,31,20,0.05) 0px, rgba(42,31,20,0.05) 1px, transparent 1px, transparent 14px),
      linear-gradient(180deg, #d8c5a4 0%, #c9b48f 55%, #b89e75 100%);
    display: grid; place-items: center; color: rgba(42,31,20,0.4);
    font-family: "Courier New", monospace; font-size: 11px; letter-spacing: 0.18em;
  }
  .news-card .body { padding: 20px 22px 18px; flex: 1; display: flex; flex-direction: column; }
  .news-card .meta {
    font-family: "Cormorant Garamond", serif; font-style: italic;
    font-size: 12px; color: var(--ink-muted); letter-spacing: 0.14em;
    margin-bottom: 8px;
  }
  .news-card h4 {
    font-family: "Amiri", serif; font-weight: 700;
    font-size: 19px; color: var(--ink); line-height: 1.35;
    margin-bottom: 10px;
  }
  .news-card .excerpt {
    font-size: 13.5px; color: var(--ink-soft); line-height: 1.7;
    flex: 1; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;
  }
  .news-card .card-foot {
    margin-top: 16px; padding-top: 14px; border-top: 1px solid var(--line-soft);
    display: flex; align-items: center; gap: 10px;
  }
  .news-card .img-count {
    font-family: "Cormorant Garamond", serif; font-style: italic;
    font-size: 12px; color: var(--ink-muted); letter-spacing: 0.08em;
    display: flex; align-items: center; gap: 6px;
  }
  .news-card .img-count svg { width: 12px; height: 12px; color: var(--gold); }
  .news-card .card-foot .spacer { flex: 1; }

  /* ---- Forms / Modal ---- */
  .modal-shroud {
    position: fixed; inset: 0; z-index: 300;
    background: rgba(42,31,20,0.45);
    display: none; align-items: flex-start; justify-content: center;
    padding: 60px 24px;
    overflow-y: auto;
    backdrop-filter: blur(2px);
  }
  .modal-shroud.open { display: flex; }
  .modal {
    background: var(--ivory);
    border: 1px solid var(--line);
    width: 100%; max-width: 760px;
    padding: 38px 44px 32px;
    position: relative;
    box-shadow: 0 30px 80px -20px rgba(42,31,20,0.4);
  }
  .modal::before {
    content: ""; position: absolute; top: 0; right: 0;
    width: 3px; height: 60px; background: var(--gold);
  }
  .modal-head {
    display: flex; align-items: flex-start; justify-content: space-between;
    gap: 24px; margin-bottom: 28px;
  }
  .modal-head .latin {
    font-family: "Cormorant Garamond", serif; font-style: italic;
    font-size: 12px; letter-spacing: 0.22em; text-transform: uppercase;
    color: var(--ink-muted); margin-bottom: 10px;
  }
  .modal-head h2 {
    font-family: "Amiri", serif; font-weight: 700;
    font-size: 32px; color: var(--ink);
  }
  .close-btn {
    width: 36px; height: 36px; border-radius: 50%;
    border: 1px solid var(--line); background: transparent;
    color: var(--ink-soft); display: grid; place-items: center;
    transition: all 0.3s ease;
  }
  .close-btn:hover { border-color: var(--ink); color: var(--ink); }
  .close-btn svg { width: 14px; height: 14px; }

  .form-grid { display: grid; gap: 18px; }
  .form-grid.two { grid-template-columns: 1fr 1fr; }
  .field { display: flex; flex-direction: column; gap: 8px; }
  .field label {
    font-size: 13px; color: var(--ink-soft); font-weight: 500;
    display: flex; align-items: center; gap: 8px;
  }
  .field label .latin {
    font-family: "Cormorant Garamond", serif; font-style: italic;
    font-size: 11px; color: var(--ink-faint); letter-spacing: 0.16em;
    text-transform: uppercase;
  }
  .field input, .field textarea, .field select {
    padding: 12px 14px;
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: 2px;
    font-size: 14.5px; color: var(--ink);
    outline: none; resize: vertical;
    transition: border-color 0.3s ease, background 0.3s ease;
  }
  .field input:focus, .field textarea:focus, .field select:focus {
    border-color: var(--ink); background: var(--ivory);
  }
  .field textarea { min-height: 140px; line-height: 1.7; }
  .field-help {
    font-family: "Cormorant Garamond", serif; font-style: italic;
    font-size: 12px; color: var(--ink-muted); letter-spacing: 0.06em;
  }

  /* Image dropzone */
  .dropzone {
    border: 1px dashed var(--line);
    background: var(--paper);
    padding: 26px 20px;
    text-align: center;
    display: flex; flex-direction: column; gap: 8px;
    align-items: center; cursor: pointer;
    transition: all 0.3s ease;
  }
  .dropzone:hover { border-color: var(--ink); background: var(--ivory-2); }
  .dropzone .icon {
    width: 38px; height: 38px; border: 1px solid var(--line);
    border-radius: 50%; display: grid; place-items: center;
    color: var(--ink-soft);
  }
  .dropzone .icon svg { width: 16px; height: 16px; }
  .dropzone .label-main { font-size: 14px; color: var(--ink); }
  .dropzone .label-sub {
    font-family: "Cormorant Garamond", serif; font-style: italic;
    font-size: 12px; color: var(--ink-muted); letter-spacing: 0.12em;
  }
  .dropzone input { display: none; }

  .image-strip {
    display: grid; grid-template-columns: repeat(auto-fill, minmax(110px, 1fr));
    gap: 10px;
    margin-top: 10px;
  }
  .image-tile {
    position: relative; aspect-ratio: 1/1;
    border: 1px solid var(--line); overflow: hidden;
    background: var(--sand);
  }
  .image-tile img { width: 100%; height: 100%; object-fit: cover; }
  .image-tile .rm {
    position: absolute; top: 4px; left: 4px;
    width: 22px; height: 22px; border-radius: 50%;
    background: rgba(42,31,20,0.7); color: var(--ivory);
    border: 0; display: grid; place-items: center;
  }
  .image-tile .rm svg { width: 10px; height: 10px; }
  .image-tile .featured-pin {
    position: absolute; bottom: 4px; right: 4px;
    background: var(--ivory); padding: 2px 8px;
    font-family: "Cormorant Garamond", serif; font-style: italic;
    font-size: 10.5px; letter-spacing: 0.16em; text-transform: uppercase;
    color: var(--ink);
  }

  .modal-foot {
    margin-top: 30px;
    padding-top: 22px;
    border-top: 1px solid var(--line-soft);
    display: flex; justify-content: flex-start; gap: 12px;
  }
  .modal-foot .spacer { flex: 1; }

  /* ---- Settings ---- */
  .settings-grid {
    display: grid; grid-template-columns: 1fr 1fr; gap: 22px;
  }
  .setting-card { padding: 30px 32px; }
  .setting-card h3 {
    font-family: "Amiri", serif; font-weight: 700;
    font-size: 22px; color: var(--ink); margin-bottom: 4px;
  }
  .setting-card .latin {
    font-family: "Cormorant Garamond", serif; font-style: italic;
    font-size: 12px; color: var(--ink-muted);
    letter-spacing: 0.18em; text-transform: uppercase;
    margin-bottom: 22px; display: block;
  }

  /* ---- Toast ---- */
  .toast {
    position: fixed; bottom: 28px; left: 50%;
    transform: translateX(-50%) translateY(20px);
    background: var(--ink); color: var(--ivory);
    padding: 14px 24px; border-radius: 2px;
    font-size: 14px; letter-spacing: 0.02em;
    opacity: 0; pointer-events: none;
    transition: all 0.4s cubic-bezier(0.22, 1, 0.36, 1);
    z-index: 400;
    display: flex; align-items: center; gap: 10px;
  }
  .toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }
  .toast svg { width: 14px; height: 14px; color: var(--gold-soft); }

  /* ---- Member cards ---- */
  .members-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 22px;
  }
  .member-card {
    background: var(--paper);
    border: 1px solid var(--line-soft);
    padding: 26px 24px 22px;
    text-align: center;
    position: relative;
    transition: all 0.4s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .member-card:hover { box-shadow: var(--shadow-card); transform: translateY(-2px); }
  .member-portrait {
    width: 112px; height: 112px; border-radius: 50%;
    margin: 0 auto 18px;
    background: var(--sand); overflow: hidden;
    border: 1px solid var(--line); position: relative;
  }
  .member-portrait img { width: 100%; height: 100%; object-fit: cover; }
  .member-portrait.empty::after {
    content: ""; position: absolute; inset: 0;
    background:
      repeating-linear-gradient(118deg, rgba(42,31,20,0.06) 0px, rgba(42,31,20,0.06) 1px, transparent 1px, transparent 10px);
  }
  .member-card h4 {
    font-family: "Amiri", serif; font-weight: 700;
    font-size: 19px; color: var(--ink); margin-bottom: 6px;
  }
  .member-card .role {
    font-size: 13.5px; color: var(--ink-muted); margin-bottom: 4px;
  }
  .member-card .latin {
    font-family: "Cormorant Garamond", serif; font-style: italic;
    font-size: 11.5px; color: var(--ink-faint);
    letter-spacing: 0.18em; text-transform: uppercase;
    margin-bottom: 18px;
  }
  .member-card .actions { display: flex; gap: 8px; justify-content: center; }

  /* ============ RESPONSIVE ============ */
  @media (max-width: 1100px) {
    .stats-grid { grid-template-columns: repeat(2, 1fr); }
    .grid-2 { grid-template-columns: 1fr; }
    .settings-grid { grid-template-columns: 1fr; }
    .topbar-search { width: 220px; }
  }
  @media (max-width: 820px) {
    .app { grid-template-columns: 1fr; }
    .sidebar {
      position: fixed; top: 0; right: 0; bottom: 0;
      width: 280px; transform: translateX(100%);
      transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1);
      z-index: 250; height: 100vh;
    }
    .sidebar.open { transform: translateX(0); }
    .scrim {
      position: fixed; inset: 0; background: rgba(42,31,20,0.4);
      z-index: 240; display: none;
    }
    .scrim.show { display: block; }
    .menu-toggle { display: inline-flex; }
    .topbar { padding: 16px 20px; gap: 14px; }
    .topbar-search { display: none; }
    .page { padding: 24px 20px 50px; }
    .form-grid.two { grid-template-columns: 1fr; }
    .modal { padding: 28px 24px 24px; }
  }
  @media (max-width: 520px) {
    .stats-grid { grid-template-columns: 1fr; }
    .toolbar .search-input { max-width: 100%; }
    table.data thead { display: none; }
    table.data tbody tr {
      display: grid; gap: 6px;
      padding: 14px 16px; border-bottom: 1px solid var(--line-soft);
    }
    table.data tbody td {
      padding: 4px 0; border: 0;
      display: grid; grid-template-columns: 110px 1fr; gap: 12px;
    }
    table.data tbody td::before {
      content: attr(data-label);
      font-family: "Cormorant Garamond", serif; font-style: italic;
      font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase;
      color: var(--ink-muted);
    }
    .row-actions { justify-content: flex-end; }
  }

</style>
</head>
<body>

<div class="grain"></div>
<div class="scrim" id="scrim"></div>

<div class="app">

  <!-- ===== SIDEBAR ===== -->
  <aside class="sidebar" id="sidebar">
    <div class="brand">
      <div class="brand-seal" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.1">
          <path d="M4 20 V12 a8 8 0 0 1 16 0 V20" />
          <circle cx="12" cy="13" r="0.9" fill="currentColor" stroke="none"/>
        </svg>
      </div>
      <div class="brand-text">
        <span class="ar">إرثٌ وحضارة</span>
        <span class="latin">Admin · Al‑Qurayyat</span>
      </div>
    </div>

    <nav>
      <div class="nav-section-label"><span>اللوحة</span></div>
      <ul class="nav-list" id="navList">
        <!-- populated by JS -->
      </ul>
    </nav>

    <div class="sidebar-foot">
      <div class="avatar">أ</div>
      <div class="who">
        <div class="name">مدير الجمعية</div>
        <div class="role">Administrator</div>
      </div>
      <button class="icon-btn" title="تسجيل الخروج" aria-label="logout">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M14 8 V6 a2 2 0 0 0 -2 -2 H6 a2 2 0 0 0 -2 2 V18 a2 2 0 0 0 2 2 H12 a2 2 0 0 0 2 -2 V16" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M10 12 H21 M18 9 L21 12 L18 15" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>
  </aside>

  <!-- ===== MAIN ===== -->
  <main class="main">
    <header class="topbar">
      <button class="menu-toggle" id="menuToggle" aria-label="menu">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M4 7 H20 M4 12 H20 M4 17 H20" stroke-linecap="round"/>
        </svg>
      </button>
      <div class="crumbs">
        <span class="crumb">إرثٌ وحضارة</span>
        <span class="sep">/</span>
        <span class="crumb">لوحة التحكم</span>
        <span class="sep">/</span>
        <span class="current" id="crumbCurrent">الرئيسية</span>
      </div>
      <div class="topbar-search">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <circle cx="11" cy="11" r="7"/><path d="M20 20 L16.5 16.5" stroke-linecap="round"/>
        </svg>
        <input type="text" placeholder="بحث سريع…" id="globalSearch" />
      </div>
      <div class="topbar-actions">
        <button class="bell-btn" id="bellBtn" title="إشعارات">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M6 9 a6 6 0 0 1 12 0 V13 L20 16 H4 L6 13 Z" stroke-linejoin="round"/>
            <path d="M10 19 a2 2 0 0 0 4 0" stroke-linecap="round"/>
          </svg>
          <span class="dot" id="bellDot" style="display:none"></span>
        </button>
      </div>
    </header>

    <div class="page" id="page">
      <!-- Pages rendered here -->
    </div>
  </main>
</div>

<!-- ===== MODAL ===== -->
<div class="modal-shroud" id="modalShroud">
  <div class="modal" id="modal" role="dialog" aria-modal="true">
    <!-- modal content injected -->
  </div>
</div>

<!-- ===== TOAST ===== -->
<div class="toast" id="toast">
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
    <path d="M5 12 L10 17 L20 7" stroke-linecap="round" stroke-linejoin="round"/>
  </svg>
  <span id="toastMsg">تم الحفظ</span>
</div>

<script>
/* ============================================================
   STATE — persisted in localStorage. Designed so it can be
   swapped for Firebase Firestore later (see firebase-adapter
   placeholder at the bottom of this file).
============================================================ */
const STORE_KEY = "erth_admin_v1";

const seed = {
  news: [
    {
      id: "n1",
      title: "ليلة الحرف القراطية — افتتاح الموسم الجديد",
      excerpt: "أمسية تراثية احتفاءً بحرفيي القريات وموروثهم الثقافي العريق، بمشاركة عددٍ من المهتمين والفنانين.",
      content: "في أمسيةٍ هادئة على ضفاف قلعة كاف، اجتمع نخبةٌ من الحرفيين والفنانين والمختصين بالتراث، احتفاءً بافتتاح موسم \"ليلة الحرف\" لهذا العام…",
      date: "2026-05-20",
      buttonText: "تفاصيل الفعالية",
      buttonUrl: "https://example.com/event",
      images: [],
      createdAt: Date.now() - 1000*60*60*24*8,
    },
    {
      id: "n2",
      title: "إطلاق مبادرة \"بيدي حرفة\" بنسختها الثالثة",
      excerpt: "مسارٌ تدريبي يجمع بين الموروث والحِرفة المعاصرة، ضمن خطّة الجمعية لتمكين الحرفيين الشباب.",
      content: "تنطلق مبادرة \"بيدي حرفة\" في نسختها الثالثة بمسارٍ أوسع، يستوعب أعداداً أكبر من المتدربين، ويُركّز على ربط الحرفة بسوقها المعاصر…",
      date: "2026-04-12",
      buttonText: "سجّل الآن",
      buttonUrl: "https://example.com/register",
      images: [],
      createdAt: Date.now() - 1000*60*60*24*40,
    },
  ],
  volunteers: [
    { id: "v1", name: "فيصل العنزي",   phone: "0551112233", city: "القريات", date: "2026-05-22", reviewed: false },
    { id: "v2", name: "ريم الشمري",    phone: "0566234455", city: "طبرجل",   date: "2026-05-21", reviewed: false },
    { id: "v3", name: "محمد المطيري",  phone: "0501239988", city: "سكاكا",   date: "2026-05-18", reviewed: true  },
    { id: "v4", name: "نوف الرويلي",   phone: "0532551122", city: "القريات", date: "2026-05-10", reviewed: true  },
  ],
  crafts: [
    { id: "c1", name: "سارة الجهني",  craft: "السدو",           city: "القريات", date: "2026-05-19", reviewed: false },
    { id: "c2", name: "خالد العنزي",  craft: "النحت على الخشب", city: "دومة الجندل", date: "2026-05-15", reviewed: false },
    { id: "c3", name: "هند الفهد",   craft: "الخط العربي",     city: "القريات", date: "2026-04-30", reviewed: true  },
  ],
  members: [
    { id: "m1", name: "د. عبدالله الرشيدي", role: "رئيس مجلس الإدارة",      image: "" },
    { id: "m2", name: "أ. منيرة العتيبي",   role: "نائب الرئيس",            image: "" },
    { id: "m3", name: "م. سلطان الشهري",   role: "أمين السر",              image: "" },
    { id: "m4", name: "د. ناصر الدوسري",   role: "المشرف الثقافي",         image: "" },
    { id: "m5", name: "أ. عبير القحطاني",  role: "المشرفة على المتطوعين",  image: "" },
  ],
  settings: {
    email: "info@erth-qurayyat.org",
    whatsapp: "+966500000000",
    location: "القريات — منطقة الجوف، المملكة العربية السعودية",
    instagram: "https://instagram.com/erth_qurayyat",
    x: "https://x.com/erth_qurayyat",
    youtube: "https://youtube.com/@erth-qurayyat",
    homepageHeadline: "إرثٌ نعتز به، وحضارةٌ نواصل بناءها",
    homepageSub: "جمعيةٌ ثقافية تُعنى بحفظ التراث والموروث الوطني، وتعزيز الهويّة الثقافية في القريات ومنطقة الجوف.",
    ctaPrimary: "اكتشف الجمعية",
    ctaSecondary: "تواصل معنا",
  },
};

const state = loadState();

function loadState() {
  try {
    const raw = localStorage.getItem(STORE_KEY);
    if (!raw) return JSON.parse(JSON.stringify(seed));
    const parsed = JSON.parse(raw);
    // ensure shape
    return { ...JSON.parse(JSON.stringify(seed)), ...parsed };
  } catch (e) {
    return JSON.parse(JSON.stringify(seed));
  }
}
function saveState() {
  try { localStorage.setItem(STORE_KEY, JSON.stringify(state)); }
  catch(e) { console.warn("save failed", e); }
}
function uid(prefix="id") { return prefix + "_" + Math.random().toString(36).slice(2, 9); }

/* ============================================================
   ROUTER / NAV
============================================================ */
const ROUTES = [
  { id: "home",       label: "الرئيسية",        latin: "Overview",   icon: iconHome },
  { id: "news",       label: "إدارة الأخبار",   latin: "Editorial",  icon: iconNews },
  { id: "volunteers", label: "المتطوعين",       latin: "Volunteers", icon: iconUsers, badgeKey: "volunteersNew" },
  { id: "crafts",     label: "بيدي حرفة",       latin: "Artisans",   icon: iconCraft, badgeKey: "craftsNew" },
  { id: "members",    label: "مجلس الإدارة",    latin: "Board",      icon: iconBoard },
  { id: "settings",   label: "الإعدادات",       latin: "Settings",   icon: iconCog },
];

let currentRoute = "home";

function renderNav() {
  const list = document.getElementById("navList");
  const counts = {
    volunteersNew: state.volunteers.filter(v => !v.reviewed).length,
    craftsNew:     state.crafts.filter(c => !c.reviewed).length,
  };
  list.innerHTML = ROUTES.map(r => {
    const active = r.id === currentRoute ? "active" : "";
    const badge = r.badgeKey && counts[r.badgeKey] > 0
      ? `<span class="nav-badge">${counts[r.badgeKey]}</span>` : "";
    return `
      <li>
        <button class="nav-item ${active}" data-route="${r.id}">
          <span class="nav-icon">${r.icon()}</span>
          <span class="nav-label">${r.label}</span>
          ${badge}
        </button>
      </li>`;
  }).join("");
  list.querySelectorAll(".nav-item").forEach(btn => {
    btn.addEventListener("click", () => {
      goTo(btn.dataset.route);
      closeSidebar();
    });
  });

  // bell dot
  const hasNew = counts.volunteersNew + counts.craftsNew > 0;
  document.getElementById("bellDot").style.display = hasNew ? "block" : "none";
}

function goTo(route) {
  currentRoute = route;
  const r = ROUTES.find(x => x.id === route);
  document.getElementById("crumbCurrent").textContent = r?.label || "";
  renderNav();
  renderPage();
  window.scrollTo({ top: 0, behavior: "smooth" });
}

/* ============================================================
   PAGE RENDERERS
============================================================ */
function renderPage() {
  const page = document.getElementById("page");
  page.innerHTML = "";
  switch (currentRoute) {
    case "home":       page.innerHTML = viewHome();       afterHome();       break;
    case "news":       page.innerHTML = viewNews();       afterNews();       break;
    case "volunteers": page.innerHTML = viewVolunteers(); afterVolunteers(); break;
    case "crafts":     page.innerHTML = viewCrafts();     afterCrafts();     break;
    case "members":    page.innerHTML = viewMembers();    afterMembers();    break;
    case "settings":   page.innerHTML = viewSettings();   afterSettings();   break;
  }
}

/* ---------- HOME ---------- */
function viewHome() {
  const newVols = state.volunteers.filter(v => !v.reviewed).length;
  const newCrafts = state.crafts.filter(c => !c.reviewed).length;
  const recent = [
    ...state.volunteers.map(v => ({ kind: "volunteer", title: `طلب تطوّع جديد — ${v.name}`, date: v.date, new: !v.reviewed })),
    ...state.crafts.map(c => ({ kind: "craft", title: `طلب "بيدي حرفة" — ${c.name} (${c.craft})`, date: c.date, new: !c.reviewed })),
    ...state.news.map(n => ({ kind: "news", title: `تم نشر مقال — ${n.title}`, date: n.date, new: false })),
  ].sort((a,b) => (b.date||"").localeCompare(a.date||"")).slice(0, 6);

  return `
    <div class="page-head">
      <div class="page-eyebrow">
        <span class="dot"></span>
        <span class="latin">Overview · ${todayLatin()}</span>
        <span class="label">لوحة التحكم</span>
      </div>
      <h1 class="page-title">مرحباً، <span class="accent">إرثٌ</span> يَتجدّد كل يوم.</h1>
      <p class="page-sub">نظرةٌ عامة على نشاط الجمعية: المقالات المنشورة، طلبات التطوع، مبادرة "بيدي حرفة"، وأعضاء مجلس الإدارة.</p>
    </div>

    <div class="stats-grid">
      ${statCard("Editorial", "عدد الأخبار",                state.news.length,        "+مقال جديد هذا الشهر")}
      ${statCard("Volunteers","عدد المتطوعين",              state.volunteers.length,  `${newVols} طلب جديد`)}
      ${statCard("Artisans",  "طلبات بيدي حرفة",            state.crafts.length,      `${newCrafts} طلب جديد`)}
      ${statCard("Board",     "أعضاء مجلس الإدارة",         state.members.length,     "مكتمل")}
    </div>

    <div class="grid-2">
      <div class="card">
        <div class="card-head">
          <div>
            <h3>النشاط الأخير</h3>
            <div class="latin">Recent activity</div>
          </div>
          <button class="btn btn-ghost btn-sm" data-go="news">عرض الأخبار</button>
        </div>
        <div class="activity-list">
          ${recent.length === 0 ? emptyState("لا يوجد نشاطٌ بعد") : recent.map(item => `
            <div class="activity-item">
              <div class="activity-marker">${activityIcon(item.kind)}</div>
              <div class="activity-body">
                <div class="activity-title">${escapeHtml(item.title)} ${item.new ? '<span class="row-status new" style="margin-inline-start:8px">جديد</span>' : ''}</div>
                <div class="activity-meta">${formatDateLatin(item.date)}</div>
              </div>
            </div>`).join("")}
        </div>
      </div>

      <div class="card">
        <div class="card-head">
          <div>
            <h3>الاختصارات</h3>
            <div class="latin">Quick actions</div>
          </div>
        </div>
        <div style="display:flex;flex-direction:column;gap:12px">
          <button class="btn btn-primary" data-action="add-news" style="justify-content:space-between;width:100%">
            <span>كتابة مقال جديد</span>
            ${chevron()}
          </button>
          <button class="btn btn-ghost" data-go="volunteers" style="justify-content:space-between;width:100%">
            <span>مراجعة طلبات التطوع</span>
            ${chevron()}
          </button>
          <button class="btn btn-ghost" data-go="crafts" style="justify-content:space-between;width:100%">
            <span>مراجعة طلبات "بيدي حرفة"</span>
            ${chevron()}
          </button>
          <button class="btn btn-ghost" data-go="settings" style="justify-content:space-between;width:100%">
            <span>تعديل إعدادات الموقع</span>
            ${chevron()}
          </button>
        </div>
      </div>
    </div>
  `;
}
function afterHome() {
  document.querySelectorAll("[data-go]").forEach(b => b.addEventListener("click", () => goTo(b.dataset.go)));
  document.querySelectorAll("[data-action='add-news']").forEach(b => b.addEventListener("click", () => openNewsModal(null)));
}

function statCard(latin, label, value, foot) {
  return `
    <div class="stat">
      <div class="stat-eyebrow">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M4 4 H20 V20 H4 Z M4 9 H20 M9 4 V20" />
        </svg>
        <span>${latin}</span>
      </div>
      <div class="stat-label">${label}</div>
      <div class="stat-value">${toArabicNumber(value)}</div>
      <div class="stat-foot">
        <span>${foot}</span>
        <span class="delta">↗</span>
      </div>
    </div>`;
}

/* ---------- NEWS ---------- */
let newsFilter = "";
function viewNews() {
  const q = newsFilter.trim();
  const filtered = state.news.filter(n =>
    !q || n.title.includes(q) || (n.excerpt||"").includes(q)
  ).sort((a,b) => (b.date||"").localeCompare(a.date||""));

  return `
    <div class="page-head">
      <div class="page-eyebrow">
        <span class="dot"></span>
        <span class="latin">Editorial · CMS</span>
        <span class="label">المحتوى</span>
      </div>
      <h1 class="page-title">إدارة <span class="accent">الأخبار</span> والمقالات</h1>
      <p class="page-sub">نشرٌ تحريريٌ هادئ. أنشئ مقالاً جديداً، أضِف صوراً متعددةً، وحدّد زر الإجراء النهائي للزائر.</p>
    </div>

    <div class="toolbar">
      <div class="search-input">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="11" cy="11" r="7"/><path d="M20 20 L16.5 16.5" stroke-linecap="round"/></svg>
        <input type="text" id="newsSearch" placeholder="بحث في المقالات…" value="${escapeAttr(q)}" />
      </div>
      <div class="spacer"></div>
      <button class="btn btn-primary" data-action="add-news">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M12 5 V19 M5 12 H19" stroke-linecap="round"/></svg>
        <span>كتابة مقال جديد</span>
      </button>
    </div>

    ${filtered.length === 0
      ? `<div class="card">${emptyState(q ? "لا توجد نتائج" : "لم يُنشر مقالٌ بعد")}</div>`
      : `<div class="news-grid">${filtered.map(renderNewsCard).join("")}</div>`}
  `;
}
function renderNewsCard(n) {
  const cover = (n.images && n.images.length)
    ? `<div class="cover"><img src="${n.images[0]}" alt="" /></div>`
    : `<div class="cover empty">PHOTOGRAPHY · DOCUMENTARY</div>`;
  return `
    <article class="news-card" data-id="${n.id}">
      ${cover}
      <div class="body">
        <div class="meta">${formatDateLatin(n.date)} · ${toArabicNumber(formatDateArShort(n.date))}</div>
        <h4>${escapeHtml(n.title)}</h4>
        <p class="excerpt">${escapeHtml(n.excerpt||"")}</p>
        <div class="card-foot">
          <span class="img-count">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="5" width="18" height="14"/><path d="M3 16 L8 11 L13 16 M14 14 L17 11 L21 15"/></svg>
            <span>${toArabicNumber(n.images?.length || 0)} صور</span>
          </span>
          <span class="spacer"></span>
          <button class="btn btn-ghost btn-sm" data-edit="${n.id}">تحرير</button>
          <button class="btn btn-danger btn-sm" data-del="${n.id}">حذف</button>
        </div>
      </div>
    </article>`;
}
function afterNews() {
  document.querySelector("[data-action='add-news']").addEventListener("click", () => openNewsModal(null));
  const search = document.getElementById("newsSearch");
  if (search) {
    search.addEventListener("input", e => { newsFilter = e.target.value; renderPage(); document.getElementById("newsSearch").focus(); });
  }
  document.querySelectorAll("[data-edit]").forEach(b => b.addEventListener("click", () => openNewsModal(b.dataset.edit)));
  document.querySelectorAll("[data-del]").forEach(b => b.addEventListener("click", () => {
    if (confirm("هل تريد حذف هذا المقال؟")) {
      state.news = state.news.filter(n => n.id !== b.dataset.del);
      saveState(); renderPage(); toast("تم حذف المقال");
    }
  }));
}

function openNewsModal(id) {
  const editing = id ? state.news.find(n => n.id === id) : null;
  const article = editing ? { ...editing } : {
    id: uid("n"), title: "", excerpt: "", content: "", date: new Date().toISOString().slice(0,10),
    buttonText: "", buttonUrl: "", images: [], createdAt: Date.now(),
  };
  if (!article.images) article.images = [];

  showModal(`
    <div class="modal-head">
      <div>
        <div class="latin">${editing ? "Edit article" : "New article"}</div>
        <h2>${editing ? "تحرير مقال" : "كتابة مقال جديد"}</h2>
      </div>
      <button class="close-btn" data-close>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6 6 L18 18 M18 6 L6 18" stroke-linecap="round"/></svg>
      </button>
    </div>

    <div class="form-grid">
      <div class="field">
        <label>عنوان المقال <span class="latin">Title</span></label>
        <input type="text" id="f_title" value="${escapeAttr(article.title)}" placeholder="مثال: ليلة الحرف القراطية…" />
      </div>

      <div class="form-grid two">
        <div class="field">
          <label>تاريخ النشر <span class="latin">Date</span></label>
          <input type="date" id="f_date" value="${escapeAttr(article.date)}" />
        </div>
        <div class="field">
          <label>نصّ زر الإجراء <span class="latin">Button text</span></label>
          <input type="text" id="f_btnText" value="${escapeAttr(article.buttonText)}" placeholder="تفاصيل / سجل / حمّل…" />
        </div>
      </div>

      <div class="field">
        <label>رابط زر الإجراء <span class="latin">Button URL</span></label>
        <input type="url" id="f_btnUrl" value="${escapeAttr(article.buttonUrl)}" placeholder="https://…" />
      </div>

      <div class="field">
        <label>المقتطف (يظهر في القائمة) <span class="latin">Excerpt</span></label>
        <textarea id="f_excerpt" placeholder="ملخّصٌ موجزٌ بسطرين…">${escapeHtml(article.excerpt)}</textarea>
      </div>

      <div class="field">
        <label>المحتوى الكامل <span class="latin">Article body</span></label>
        <textarea id="f_content" style="min-height:220px" placeholder="نصُّ المقالة كاملاً…">${escapeHtml(article.content)}</textarea>
        <span class="field-help">يُعرض كتجربةٍ تحريرية أنيقة على الموقع — الفقرات تُفصل بسطرٍ فارغ.</span>
      </div>

      <div class="field">
        <label>الصور <span class="latin">Gallery (multiple)</span></label>
        <label class="dropzone" for="f_images">
          <span class="icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 5 V15 M8 9 L12 5 L16 9" stroke-linecap="round" stroke-linejoin="round"/><path d="M4 17 V19 a1 1 0 0 0 1 1 H19 a1 1 0 0 0 1 -1 V17"/></svg></span>
          <span class="label-main">اسحب الصور هنا أو اختر من الجهاز</span>
          <span class="label-sub">Multiple images · Original quality preserved</span>
          <input type="file" id="f_images" multiple accept="image/*" />
        </label>
        <div class="image-strip" id="imageStrip"></div>
        <span class="field-help">الصورة الأولى تُستخدم كصورةٍ رئيسية. أعِد ترتيب الصور بسحبها أو احذف ما تشاء.</span>
      </div>
    </div>

    <div class="modal-foot">
      ${editing ? `<button class="btn btn-danger" data-del-article>حذف</button>` : ""}
      <div class="spacer"></div>
      <button class="btn btn-ghost" data-close>إلغاء</button>
      <button class="btn btn-primary" data-save-article>
        <span>${editing ? "حفظ التعديلات" : "نشر المقال"}</span>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 12 H19 M13 6 L19 12 L13 18" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
    </div>
  `);

  // image handling — base64, no forced dimensions
  const strip = document.getElementById("imageStrip");
  const renderStrip = () => {
    strip.innerHTML = article.images.map((src, i) => `
      <div class="image-tile">
        <img src="${src}" alt="" />
        <button class="rm" data-rm="${i}" title="إزالة">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 6 L18 18 M18 6 L6 18" stroke-linecap="round"/></svg>
        </button>
        ${i === 0 ? `<span class="featured-pin">Featured</span>` : ""}
      </div>
    `).join("");
    strip.querySelectorAll("[data-rm]").forEach(b => b.addEventListener("click", () => {
      article.images.splice(parseInt(b.dataset.rm,10), 1); renderStrip();
    }));
  };
  renderStrip();
  document.getElementById("f_images").addEventListener("change", async (e) => {
    const files = Array.from(e.target.files || []);
    for (const f of files) {
      const dataUrl = await fileToBase64(f);
      article.images.push(dataUrl);
    }
    renderStrip();
    e.target.value = "";
  });

  document.querySelector("[data-save-article]").addEventListener("click", () => {
    article.title    = document.getElementById("f_title").value.trim();
    article.date     = document.getElementById("f_date").value;
    article.buttonText = document.getElementById("f_btnText").value.trim();
    article.buttonUrl  = document.getElementById("f_btnUrl").value.trim();
    article.excerpt  = document.getElementById("f_excerpt").value.trim();
    article.content  = document.getElementById("f_content").value.trim();
    if (!article.title) { toast("الرجاء إدخال عنوان المقال"); return; }
    if (editing) {
      state.news = state.news.map(n => n.id === article.id ? article : n);
    } else {
      state.news.unshift(article);
    }
    saveState(); closeModal(); renderPage();
    toast(editing ? "تم حفظ التعديلات" : "تم نشر المقال");
  });
  const delBtn = document.querySelector("[data-del-article]");
  if (delBtn) delBtn.addEventListener("click", () => {
    if (confirm("حذف هذا المقال نهائياً؟")) {
      state.news = state.news.filter(n => n.id !== article.id);
      saveState(); closeModal(); renderPage(); toast("تم حذف المقال");
    }
  });
}

/* ---------- VOLUNTEERS ---------- */
let volFilter = "";
let volMode = "all"; // all | new
function viewVolunteers() {
  const q = volFilter.trim();
  let rows = [...state.volunteers];
  if (volMode === "new") rows = rows.filter(v => !v.reviewed);
  if (q) rows = rows.filter(v => v.name.includes(q) || v.phone.includes(q) || v.city.includes(q));
  rows.sort((a,b) => (b.date||"").localeCompare(a.date||""));

  return `
    <div class="page-head">
      <div class="page-eyebrow">
        <span class="dot"></span>
        <span class="latin">Volunteers · Applications</span>
        <span class="label">طلبات التطوع</span>
      </div>
      <h1 class="page-title">إدارة <span class="accent">المتطوعين</span></h1>
      <p class="page-sub">طلبات التطوع الواردة من زوّار الموقع. راجِع، اعتمد، أو احذف.</p>
    </div>

    <div class="toolbar">
      <div class="search-input">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="11" cy="11" r="7"/><path d="M20 20 L16.5 16.5" stroke-linecap="round"/></svg>
        <input type="text" id="volSearch" placeholder="بحث بالاسم، الهاتف، المدينة…" value="${escapeAttr(q)}" />
      </div>
      <div class="filters">
        <button class="chip ${volMode==='all'?'active':''}" data-vmode="all">الكل</button>
        <button class="chip ${volMode==='new'?'active':''}" data-vmode="new">الطلبات الجديدة</button>
      </div>
    </div>

    ${rows.length === 0
      ? `<div class="card">${emptyState("لا توجد طلبات تطوع")}</div>`
      : `
        <div class="table-wrap">
          <table class="data">
            <thead><tr>
              <th>المتطوع</th><th>الهاتف</th><th>المدينة</th><th>التاريخ</th><th>الحالة</th><th>إجراءات</th>
            </tr></thead>
            <tbody>
              ${rows.map(v => `
                <tr>
                  <td data-label="المتطوع"><div class="name-cell"><div class="avatar" style="width:34px;height:34px;font-size:14px">${initial(v.name)}</div>${escapeHtml(v.name)}</div></td>
                  <td data-label="الهاتف" style="direction:ltr;text-align:right">${escapeHtml(v.phone)}</td>
                  <td data-label="المدينة">${escapeHtml(v.city)}</td>
                  <td data-label="التاريخ">${formatDateLatin(v.date)}</td>
                  <td data-label="الحالة"><span class="row-status ${v.reviewed?'reviewed':'new'}">${v.reviewed?'تمت المراجعة':'جديد'}</span></td>
                  <td data-label="إجراءات">
                    <div class="row-actions">
                      ${v.reviewed
                        ? `<button data-unreview="${v.id}">إعادة كجديد</button>`
                        : `<button class="ok" data-review="${v.id}"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 12 L10 17 L20 7" stroke-linecap="round" stroke-linejoin="round"/></svg> اعتماد</button>`}
                      <button class="del" data-del-v="${v.id}"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 7 H19 M9 7 V5 a1 1 0 0 1 1 -1 H14 a1 1 0 0 1 1 1 V7 M7 7 L8 20 H16 L17 7" stroke-linecap="round" stroke-linejoin="round"/></svg> حذف</button>
                    </div>
                  </td>
                </tr>
              `).join("")}
            </tbody>
          </table>
        </div>`}
  `;
}
function afterVolunteers() {
  const s = document.getElementById("volSearch");
  if (s) s.addEventListener("input", e => { volFilter = e.target.value; renderPage(); document.getElementById("volSearch").focus(); });
  document.querySelectorAll("[data-vmode]").forEach(b => b.addEventListener("click", () => { volMode = b.dataset.vmode; renderPage(); }));
  document.querySelectorAll("[data-review]").forEach(b => b.addEventListener("click", () => {
    const v = state.volunteers.find(x => x.id === b.dataset.review); if (v) { v.reviewed = true; saveState(); renderNav(); renderPage(); toast("تم اعتماد الطلب"); }
  }));
  document.querySelectorAll("[data-unreview]").forEach(b => b.addEventListener("click", () => {
    const v = state.volunteers.find(x => x.id === b.dataset.unreview); if (v) { v.reviewed = false; saveState(); renderNav(); renderPage(); }
  }));
  document.querySelectorAll("[data-del-v]").forEach(b => b.addEventListener("click", () => {
    if (confirm("حذف الطلب؟")) {
      state.volunteers = state.volunteers.filter(v => v.id !== b.dataset.delV);
      saveState(); renderNav(); renderPage(); toast("تم الحذف");
    }
  }));
}

/* ---------- CRAFTS (بيدي حرفة) ---------- */
let craftFilter = "";
let craftMode = "all";
function viewCrafts() {
  const q = craftFilter.trim();
  let rows = [...state.crafts];
  if (craftMode === "new") rows = rows.filter(c => !c.reviewed);
  if (q) rows = rows.filter(c => c.name.includes(q) || c.craft.includes(q) || c.city.includes(q));
  rows.sort((a,b) => (b.date||"").localeCompare(a.date||""));

  return `
    <div class="page-head">
      <div class="page-eyebrow">
        <span class="dot"></span>
        <span class="latin">Artisans · بيدي حرفة</span>
        <span class="label">المبادرة الحرفية</span>
      </div>
      <h1 class="page-title">إدارة طلبات <span class="accent">بيدي حرفة</span></h1>
      <p class="page-sub">المشاركون في مبادرة "بيدي حرفة" — حرفيّو القريات ومنطقة الجوف.</p>
    </div>

    <div class="toolbar">
      <div class="search-input">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="11" cy="11" r="7"/><path d="M20 20 L16.5 16.5" stroke-linecap="round"/></svg>
        <input type="text" id="craftSearch" placeholder="بحث…" value="${escapeAttr(q)}" />
      </div>
      <div class="filters">
        <button class="chip ${craftMode==='all'?'active':''}" data-cmode="all">الكل</button>
        <button class="chip ${craftMode==='new'?'active':''}" data-cmode="new">الجديدة</button>
      </div>
    </div>

    ${rows.length === 0
      ? `<div class="card">${emptyState("لا توجد طلبات بعد")}</div>`
      : `
        <div class="table-wrap">
          <table class="data">
            <thead><tr>
              <th>المشارك</th><th>الحرفة</th><th>المدينة</th><th>التاريخ</th><th>الحالة</th><th>إجراءات</th>
            </tr></thead>
            <tbody>
              ${rows.map(c => `
                <tr>
                  <td data-label="المشارك"><div class="name-cell"><div class="avatar" style="width:34px;height:34px;font-size:14px">${initial(c.name)}</div>${escapeHtml(c.name)}</div></td>
                  <td data-label="الحرفة">${escapeHtml(c.craft)}</td>
                  <td data-label="المدينة">${escapeHtml(c.city)}</td>
                  <td data-label="التاريخ">${formatDateLatin(c.date)}</td>
                  <td data-label="الحالة"><span class="row-status ${c.reviewed?'reviewed':'new'}">${c.reviewed?'تمت المراجعة':'جديد'}</span></td>
                  <td data-label="إجراءات">
                    <div class="row-actions">
                      ${c.reviewed
                        ? `<button data-unreview-c="${c.id}">إعادة كجديد</button>`
                        : `<button class="ok" data-review-c="${c.id}"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 12 L10 17 L20 7" stroke-linecap="round" stroke-linejoin="round"/></svg> اعتماد</button>`}
                      <button class="del" data-del-c="${c.id}"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 7 H19 M9 7 V5 a1 1 0 0 1 1 -1 H14 a1 1 0 0 1 1 1 V7 M7 7 L8 20 H16 L17 7" stroke-linecap="round" stroke-linejoin="round"/></svg> حذف</button>
                    </div>
                  </td>
                </tr>
              `).join("")}
            </tbody>
          </table>
        </div>`}
  `;
}
function afterCrafts() {
  const s = document.getElementById("craftSearch");
  if (s) s.addEventListener("input", e => { craftFilter = e.target.value; renderPage(); document.getElementById("craftSearch").focus(); });
  document.querySelectorAll("[data-cmode]").forEach(b => b.addEventListener("click", () => { craftMode = b.dataset.cmode; renderPage(); }));
  document.querySelectorAll("[data-review-c]").forEach(b => b.addEventListener("click", () => {
    const c = state.crafts.find(x => x.id === b.dataset.reviewC); if (c) { c.reviewed = true; saveState(); renderNav(); renderPage(); toast("تم اعتماد الطلب"); }
  }));
  document.querySelectorAll("[data-unreview-c]").forEach(b => b.addEventListener("click", () => {
    const c = state.crafts.find(x => x.id === b.dataset.unreviewC); if (c) { c.reviewed = false; saveState(); renderNav(); renderPage(); }
  }));
  document.querySelectorAll("[data-del-c]").forEach(b => b.addEventListener("click", () => {
    if (confirm("حذف الطلب؟")) {
      state.crafts = state.crafts.filter(c => c.id !== b.dataset.delC);
      saveState(); renderNav(); renderPage(); toast("تم الحذف");
    }
  }));
}

/* ---------- MEMBERS ---------- */
function viewMembers() {
  return `
    <div class="page-head">
      <div class="page-eyebrow">
        <span class="dot"></span>
        <span class="latin">Board · Governance</span>
        <span class="label">مجلس الإدارة</span>
      </div>
      <h1 class="page-title">إدارة <span class="accent">أعضاء</span> مجلس الإدارة</h1>
      <p class="page-sub">قائمة الأعضاء كما تظهر على الموقع الرسمي — الأسماء، المسميات، والصور.</p>
    </div>

    <div class="toolbar">
      <div class="spacer"></div>
      <button class="btn btn-primary" data-add-member>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M12 5 V19 M5 12 H19" stroke-linecap="round"/></svg>
        <span>إضافة عضو</span>
      </button>
    </div>

    ${state.members.length === 0
      ? `<div class="card">${emptyState("لم يُضَف عضوٌ بعد")}</div>`
      : `<div class="members-grid">${state.members.map(m => `
          <article class="member-card">
            <div class="member-portrait ${m.image ? '' : 'empty'}">
              ${m.image ? `<img src="${m.image}" alt="" />` : ''}
            </div>
            <h4>${escapeHtml(m.name)}</h4>
            <div class="role">${escapeHtml(m.role)}</div>
            <div class="latin">Board member</div>
            <div class="actions">
              <button class="btn btn-ghost btn-sm" data-edit-m="${m.id}">تحرير</button>
              <button class="btn btn-danger btn-sm" data-del-m="${m.id}">حذف</button>
            </div>
          </article>
        `).join("")}</div>`}
  `;
}
function afterMembers() {
  document.querySelectorAll("[data-add-member]").forEach(b => b.addEventListener("click", () => openMemberModal(null)));
  document.querySelectorAll("[data-edit-m]").forEach(b => b.addEventListener("click", () => openMemberModal(b.dataset.editM)));
  document.querySelectorAll("[data-del-m]").forEach(b => b.addEventListener("click", () => {
    if (confirm("حذف العضو؟")) {
      state.members = state.members.filter(m => m.id !== b.dataset.delM);
      saveState(); renderPage(); toast("تم الحذف");
    }
  }));
}
function openMemberModal(id) {
  const editing = id ? state.members.find(m => m.id === id) : null;
  const member = editing ? { ...editing } : { id: uid("m"), name: "", role: "", image: "" };

  showModal(`
    <div class="modal-head">
      <div>
        <div class="latin">${editing ? "Edit member" : "Add member"}</div>
        <h2>${editing ? "تحرير عضو" : "إضافة عضو جديد"}</h2>
      </div>
      <button class="close-btn" data-close>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6 6 L18 18 M18 6 L6 18" stroke-linecap="round"/></svg>
      </button>
    </div>

    <div class="form-grid">
      <div class="form-grid two">
        <div class="field">
          <label>الاسم الكامل <span class="latin">Name</span></label>
          <input type="text" id="m_name" value="${escapeAttr(member.name)}" placeholder="مثال: د. عبدالله الرشيدي" />
        </div>
        <div class="field">
          <label>المسمى <span class="latin">Position</span></label>
          <input type="text" id="m_role" value="${escapeAttr(member.role)}" placeholder="رئيس مجلس الإدارة…" />
        </div>
      </div>

      <div class="field">
        <label>الصورة الشخصية <span class="latin">Portrait</span></label>
        <label class="dropzone" for="m_image" id="m_imageDrop">
          <span class="icon">${member.image
            ? `<img src="${member.image}" style="width:38px;height:38px;border-radius:50%;object-fit:cover" />`
            : `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="9" r="3.5"/><path d="M5 20 a7 7 0 0 1 14 0"/></svg>`}</span>
          <span class="label-main">${member.image ? "تغيير الصورة" : "اختر صورةً للعضو"}</span>
          <span class="label-sub">JPEG / PNG · Square recommended</span>
          <input type="file" id="m_image" accept="image/*" />
        </label>
      </div>
    </div>

    <div class="modal-foot">
      ${editing ? `<button class="btn btn-danger" data-del-member>حذف</button>` : ""}
      <div class="spacer"></div>
      <button class="btn btn-ghost" data-close>إلغاء</button>
      <button class="btn btn-primary" data-save-member>
        <span>${editing ? "حفظ التعديلات" : "إضافة العضو"}</span>
      </button>
    </div>
  `);

  document.getElementById("m_image").addEventListener("change", async e => {
    const f = e.target.files?.[0]; if (!f) return;
    member.image = await fileToBase64(f);
    document.getElementById("m_imageDrop").querySelector(".icon").innerHTML =
      `<img src="${member.image}" style="width:38px;height:38px;border-radius:50%;object-fit:cover" />`;
    document.getElementById("m_imageDrop").querySelector(".label-main").textContent = "تغيير الصورة";
  });

  document.querySelector("[data-save-member]").addEventListener("click", () => {
    member.name = document.getElementById("m_name").value.trim();
    member.role = document.getElementById("m_role").value.trim();
    if (!member.name) { toast("الرجاء إدخال الاسم"); return; }
    if (editing) {
      state.members = state.members.map(m => m.id === member.id ? member : m);
    } else {
      state.members.push(member);
    }
    saveState(); closeModal(); renderPage(); toast(editing ? "تم حفظ التعديلات" : "تمت إضافة العضو");
  });
  const delBtn = document.querySelector("[data-del-member]");
  if (delBtn) delBtn.addEventListener("click", () => {
    if (confirm("حذف العضو؟")) {
      state.members = state.members.filter(m => m.id !== member.id);
      saveState(); closeModal(); renderPage(); toast("تم الحذف");
    }
  });
}

/* ---------- SETTINGS ---------- */
function viewSettings() {
  const s = state.settings;
  return `
    <div class="page-head">
      <div class="page-eyebrow">
        <span class="dot"></span>
        <span class="latin">Settings · Site preferences</span>
        <span class="label">الإعدادات</span>
      </div>
      <h1 class="page-title">إعدادات <span class="accent">الموقع</span></h1>
      <p class="page-sub">روابط التواصل، النصوص الرئيسية على الصفحة الأولى، ومعلومات الجمعية العامة.</p>
    </div>

    <div class="settings-grid">
      <div class="card setting-card">
        <h3>التواصل</h3>
        <span class="latin">Contact</span>
        <div class="form-grid">
          <div class="field">
            <label>البريد الإلكتروني <span class="latin">Email</span></label>
            <input type="email" data-s="email" value="${escapeAttr(s.email)}" />
          </div>
          <div class="field">
            <label>واتساب <span class="latin">WhatsApp</span></label>
            <input type="text" data-s="whatsapp" value="${escapeAttr(s.whatsapp)}" />
          </div>
          <div class="field">
            <label>الموقع الجغرافي <span class="latin">Location</span></label>
            <input type="text" data-s="location" value="${escapeAttr(s.location)}" />
          </div>
        </div>
      </div>

      <div class="card setting-card">
        <h3>روابط التواصل الاجتماعي</h3>
        <span class="latin">Social links</span>
        <div class="form-grid">
          <div class="field">
            <label>إنستغرام <span class="latin">Instagram URL</span></label>
            <input type="url" data-s="instagram" value="${escapeAttr(s.instagram)}" />
          </div>
          <div class="field">
            <label>X (تويتر) <span class="latin">X / Twitter URL</span></label>
            <input type="url" data-s="x" value="${escapeAttr(s.x)}" />
          </div>
          <div class="field">
            <label>يوتيوب <span class="latin">YouTube URL</span></label>
            <input type="url" data-s="youtube" value="${escapeAttr(s.youtube)}" />
          </div>
        </div>
      </div>

      <div class="card setting-card" style="grid-column:1 / -1">
        <h3>نصوص الصفحة الرئيسية</h3>
        <span class="latin">Homepage hero copy</span>
        <div class="form-grid">
          <div class="field">
            <label>العنوان الرئيسي <span class="latin">Headline</span></label>
            <input type="text" data-s="homepageHeadline" value="${escapeAttr(s.homepageHeadline)}" />
          </div>
          <div class="field">
            <label>الوصف <span class="latin">Subhead</span></label>
            <textarea data-s="homepageSub" style="min-height:90px">${escapeHtml(s.homepageSub)}</textarea>
          </div>
          <div class="form-grid two">
            <div class="field">
              <label>زر الإجراء الرئيسي <span class="latin">CTA primary</span></label>
              <input type="text" data-s="ctaPrimary" value="${escapeAttr(s.ctaPrimary)}" />
            </div>
            <div class="field">
              <label>زر الإجراء الثانوي <span class="latin">CTA secondary</span></label>
              <input type="text" data-s="ctaSecondary" value="${escapeAttr(s.ctaSecondary)}" />
            </div>
          </div>
        </div>
      </div>
    </div>

    <div style="display:flex;gap:12px;margin-top:28px;justify-content:flex-end">
      <button class="btn btn-ghost" data-reset-settings>إعادة للقيم الافتراضية</button>
      <button class="btn btn-primary" data-save-settings>
        <span>حفظ الإعدادات</span>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 12 L10 17 L20 7" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
    </div>
  `;
}
function afterSettings() {
  document.querySelector("[data-save-settings]").addEventListener("click", () => {
    document.querySelectorAll("[data-s]").forEach(el => { state.settings[el.dataset.s] = el.value; });
    saveState(); toast("تم حفظ الإعدادات");
  });
  document.querySelector("[data-reset-settings]").addEventListener("click", () => {
    if (confirm("إعادة جميع الإعدادات للقيم الافتراضية؟")) {
      state.settings = JSON.parse(JSON.stringify(seed.settings));
      saveState(); renderPage(); toast("تمت الإعادة");
    }
  });
}

/* ============================================================
   MODAL / TOAST
============================================================ */
function showModal(html) {
  const shroud = document.getElementById("modalShroud");
  document.getElementById("modal").innerHTML = html;
  shroud.classList.add("open");
  document.body.style.overflow = "hidden";
  shroud.querySelectorAll("[data-close]").forEach(b => b.addEventListener("click", closeModal));
}
function closeModal() {
  document.getElementById("modalShroud").classList.remove("open");
  document.body.style.overflow = "";
}
document.getElementById("modalShroud").addEventListener("click", (e) => {
  if (e.target.id === "modalShroud") closeModal();
});

let toastTimer;
function toast(msg) {
  const t = document.getElementById("toast");
  document.getElementById("toastMsg").textContent = msg;
  t.classList.add("show");
  clearTimeout(toastTimer);
  toastTimer = setTimeout(() => t.classList.remove("show"), 2400);
}

/* ============================================================
   SIDEBAR (mobile)
============================================================ */
const sidebar = document.getElementById("sidebar");
const scrim   = document.getElementById("scrim");
document.getElementById("menuToggle").addEventListener("click", () => {
  sidebar.classList.add("open"); scrim.classList.add("show");
});
function closeSidebar() { sidebar.classList.remove("open"); scrim.classList.remove("show"); }
scrim.addEventListener("click", closeSidebar);

/* ============================================================
   UTILITIES
============================================================ */
function escapeHtml(s) {
  return (s ?? "").toString()
    .replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;");
}
function escapeAttr(s) {
  return (s ?? "").toString()
    .replace(/&/g, "&amp;").replace(/"/g, "&quot;").replace(/</g, "&lt;");
}
function initial(name) { return (name || "").trim().charAt(0); }
function toArabicNumber(n) {
  return String(n).replace(/[0-9]/g, d => "٠١٢٣٤٥٦٧٨٩"[+d]);
}
function todayLatin() {
  return new Date().toLocaleDateString("en-GB", { day: "2-digit", month: "short", year: "numeric" });
}
function formatDateLatin(d) {
  if (!d) return "—";
  try {
    const dt = new Date(d);
    return dt.toLocaleDateString("en-GB", { day: "2-digit", month: "short", year: "numeric" });
  } catch { return d; }
}
function formatDateArShort(d) {
  if (!d) return "";
  const [y,m,day] = d.split("-"); return `${day}/${m}/${y}`;
}
async function fileToBase64(file) {
  return new Promise((res, rej) => {
    const r = new FileReader();
    r.onload = () => res(r.result); r.onerror = rej;
    r.readAsDataURL(file);
  });
}

function emptyState(msg) {
  return `<div class="empty-state">
    <div class="glyph">۞</div>
    <div>${escapeHtml(msg)}</div>
    <div class="latin">Nothing to show</div>
  </div>`;
}
function chevron() {
  return `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="width:14px;height:14px;transform:scaleX(-1)"><path d="M5 12 H19 M13 6 L19 12 L13 18" stroke-linecap="round" stroke-linejoin="round"/></svg>`;
}
function activityIcon(kind) {
  if (kind === "volunteer") return `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="9" r="3"/><path d="M5 20 a7 7 0 0 1 14 0"/></svg>`;
  if (kind === "craft")     return `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 19 L11 13 M12 5 L19 12 L14 17 L7 10 Z"/></svg>`;
  return `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="4" y="5" width="16" height="14"/><path d="M4 10 H20 M8 5 V19"/></svg>`;
}

/* nav icons */
function iconHome()  { return `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 11 L12 4 L20 11 V20 H4 Z M10 20 V14 H14 V20" stroke-linejoin="round"/></svg>`; }
function iconNews()  { return `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="4" y="5" width="16" height="14"/><path d="M4 9 H20 M8 13 H16 M8 16 H13"/></svg>`; }
function iconUsers() { return `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="9" cy="9" r="3"/><path d="M3 19 a6 6 0 0 1 12 0"/><circle cx="17" cy="8" r="2.2"/><path d="M14 19 a4 4 0 0 1 7 0"/></svg>`; }
function iconCraft() { return `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 3 L14 8 L19 8 L15 12 L17 18 L12 14 L7 18 L9 12 L5 8 L10 8 Z"/></svg>`; }
function iconBoard() { return `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="6" width="18" height="13" rx="1"/><path d="M3 10 H21 M9 6 V4 H15 V6"/></svg>`; }
function iconCog()   { return `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="3"/><path d="M12 3 V5 M12 19 V21 M3 12 H5 M19 12 H21 M5.5 5.5 L7 7 M17 17 L18.5 18.5 M5.5 18.5 L7 17 M17 7 L18.5 5.5"/></svg>`; }

/* ============================================================
   FIREBASE ADAPTER PLACEHOLDER
   ----------------------------------------------------------
   Architecture is ready for Firebase Firestore + Storage.
   Replace `saveState()` / `loadState()` with Firestore calls,
   and `fileToBase64` with Storage uploads. Hooks:
     - news        →  collection("news")
     - volunteers  →  collection("volunteers")
     - crafts      →  collection("crafts")
     - members     →  collection("members")
     - settings    →  doc("settings/site")
   Auth gate would wrap the main render call below.
============================================================ */

/* ============================================================
   BOOT
============================================================ */
renderNav();
renderPage();
</script>
</body>
</html>
